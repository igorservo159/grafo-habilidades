<node id="EF06CI02">
  <data key="d0">Ciências</data>
  <data key="d1">identificar evidencias de transformacoes quimicas a partir do resultado de misturas de materiais que originam produtos diferentes dos que foram misturados (mistura de ingredientes para fazer um bolo, mistura de vinagre com bicarbonato de sodio etc.).</data>
  <data key="d2">Base</data>
