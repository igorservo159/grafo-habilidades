<node id="EF05GE07">
  <data key="d0">Geografia</data>
  <data key="d1">identificar os diferentes tipos de energia utilizados na producao industrial, agricola e extrativa e no cotidiano das populacoes.</data>
  <data key="d2">Base</data>
</node>
<node id="EF05GE08">
  <data key="d0">Geografia</data>
  <data key="d1">analisar transformacoes de paisagens nas cidades, comparando sequencia de fotografias, fotografias aereas e imagens de satelite de epocas diferentes.</data>
