<node id="EF03CI04">
  <data key="d0">Ciências</data>
  <data key="d1">identificar caracteristicas sobre o modo de vida (o que comem, como se reproduzem, como se deslocam etc.) dos animais mais comuns no ambiente proximo.</data>
