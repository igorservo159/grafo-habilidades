  <data key="d2">Base</data>
</node>
<node id="EF69AR16">
  <data key="d0">Arte</data>
  <data key="d1">analisar criticamente, por meio da apreciacao musical, usos e funcoes da musica em seus contextos de producao e circulacao, relacionando as praticas musicais as diferentes dimensoes da vida social, cultural, politica, historica, economica, estetica e etica</data>
