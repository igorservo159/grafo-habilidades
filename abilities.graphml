  <data key="d2">Base</data>
</node>
<node id="EF06LI15">
  <data key="d0">Lingua Inglesa</data>
  <data key="d1">produzir textos escritos em lingua inglesa (historias em quadrinhos, cartazes, chats, blogues, agendas, fotolegendas, entre outros), sobre si mesmo, sua familia, seus amigos, gostos, preferencias e rotinas, sua comunidade e seu contexto escolar.</data>
