</node>
<node id="EF06LI03">
  <data key="d0">Lingua Inglesa</data>
  <data key="d1">solicitar esclarecimentos em lingua inglesa sobre o que nao entendeu e o significado de palavras ou expressoes desconhecidas.</data>
